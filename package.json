{
  "name": "bible-song-pro-vmix-desktop",
  "version": "2.1.0",
  "description": "Bible Song Pro desktop preview wrapper for macOS",
  "main": "electron/main.js",
  "author": "Johnson Olakotan",
  "license": "UNLICENSED",
  "private": true,
  "scripts": {
    "start": "node scripts/launch.js",
    "helper": "node scripts/launch.js helper-app/main.js",
    "feedback:server": "node server/feedback-backend.js",
    "pack:mac": "electron-builder --mac dir",
    "dist:mac": "electron-builder --mac",
    "pack:win": "electron-builder --win nsis portable",
    "dist:win": "electron-builder --win",
    "dist:linux": "electron-builder --linux",
    "helper:pack:mac": "electron-builder --mac dir --x64 --config electron-builder.helper.yml",
    "helper:dist:mac": "electron-builder --mac --x64 --config electron-builder.helper.yml",
    "helper:pack:mac:arm64": "electron-builder --mac dir --arm64 --config electron-builder.helper.yml",
    "helper:dist:mac:arm64": "electron-builder --mac --arm64 --config electron-builder.helper.yml",
    "helper:pack:mac:universal": "electron-builder --mac dir --universal --config electron-builder.helper.yml",
    "helper:dist:mac:universal": "electron-builder --mac --universal --config electron-builder.helper.yml",
    "helper:pack:win": "electron-builder --win nsis portable --config electron-builder.helper.yml",
    "helper:dist:win": "electron-builder --win --config electron-builder.helper.yml",
    "helper:dist:linux": "electron-builder --linux --config electron-builder.helper.yml"
  },
  "build": {
    "appId": "com.biblesongpro.desktop",
    "productName": "Bible Song Pro",
    "files": [
      "Bible Song Pro panel.html",
      "BSP_display.html",
      "index.html",
      "dock.html",
      "assets/**/*",
      "css/**/*",
      "js/**/*",
      "electron/**/*",
      "helper-app/**/*",
      "scripts/**/*",
      "package.json",
      "README.md",
      "LICENSE"
    ],
    "directories": {
      "buildResources": "electron/resources",
      "output": "dist"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "Johnbatey",
        "repo": "bible-song-pro-obs"
      }
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "bible-song-pro-icon.icns",
      "identity": null,
      "target": [
        "dir",
        "zip"
      ],
      "artifactName": "${productName}-${version}-mac-${arch}.${ext}"
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "bible-song-pro-icon.ico",
      "publisherName": "Johnson Olakotan"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "artifactName": "${productName} Setup-${version}-win-${arch}.${ext}"
    },
    "portable": {
      "artifactName": "${productName} Portable-${version}-win-${arch}.${ext}"
    },
    "linux": {
      "target": [
        "AppImage",
        "zip"
      ],
      "icon": "electron/resources/linux-icon.png",
      "category": "Utility",
      "artifactName": "${productName}-${version}-linux-${arch}.${ext}"
    }
  },
  "dependencies": {
    "electron-updater": "^6.6.2",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "electron": "^31.7.7",
    "electron-builder": "^24.13.3"
  }
}
